@page "/"
@using BlazorAsteroids.Game.Engine
@using BlazorAsteroids.Game.Interfaces
@using BlazorAsteroids.Game.Models
@using System.Threading
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error-container">
        <p class="error-message">@errorMessage</p>
        <button @onclick="RetryInitialization">Retry</button>
    </div>
}

<div style="position: relative; width: @(ViewportWidth)px; height: @(ViewportHeight)px;">
    <canvas @ref="canvasRef" width="@ViewportWidth" height="@ViewportHeight" tabindex="0"
            style="display: block;"></canvas>
    <div style="position: absolute; top: 10px; left: 10px; color: white; font-size: 18px; font-family: monospace; text-shadow: 1px 1px 2px black;">
        Health: @(gameState?.Player.Health ?? 0)
    </div>
    <div style="position: absolute; top: 10px; right: 10px; color: white; font-size: 18px; font-family: monospace; text-shadow: 1px 1px 2px black;">
        Score: @(gameState?.Player.Score ?? 0)
    </div>
</div>

@code {
    private const int ViewportWidth = 800;
    private const int ViewportHeight = 600;

    // World is ~6x the viewport area so the camera shows ~1/6 of the map
    private const float WorldWidth = 2000f;
    private const float WorldHeight = 1500f;

    private ElementReference canvasRef;
    private GameLoop? gameLoop;
    private GameState? gameState;
    private string? errorMessage;
    private Timer? _uiRefreshTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeGameAsync();
        }
    }

    private async Task InitializeGameAsync()
    {
        try
        {
            errorMessage = null;

            var inputManager = new InputManager();
            var renderer = new CanvasRenderer(JSRuntime);

            var camera = new Camera
            {
                ViewportWidth = ViewportWidth,
                ViewportHeight = ViewportHeight,
                WorldWidth = WorldWidth,
                WorldHeight = WorldHeight
            };

            gameState = new GameState
            {
                CanvasWidth = ViewportWidth,
                CanvasHeight = ViewportHeight,
                WorldWidth = WorldWidth,
                WorldHeight = WorldHeight,
                Camera = camera,
                Player = new Player
                {
                    Position = new Vector2(WorldWidth / 2f, WorldHeight / 2f),
                    Speed = 200f,
                    Size = 15f,
                    Rotation = 0f
                }
            };

            // Position camera on player immediately so it's visible on first frame
            camera.SnapTo(gameState.Player.Position);

            gameLoop = new GameLoop(JSRuntime, inputManager, gameState, renderer);
            await gameLoop.InitializeAsync(canvasRef);

            // Re-render the component so the UI displays the initial Player values (Health, Score)
            // since gameState was null during the first render pass.
            StateHasChanged();

            // Periodically re-render the UI so the HTML overlay (Health, Score) stays
            // in sync with game state updates driven by the JS game loop.
            _uiRefreshTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 0, 100);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to initialize game: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task RetryInitialization()
    {
        await InitializeGameAsync();
    }

    public void Dispose()
    {
        _uiRefreshTimer?.Dispose();
    }
}
